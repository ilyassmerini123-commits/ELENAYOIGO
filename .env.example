# --- CONFIGURACIÓN PARA ELENAAI.TECH (EUROPE-WEST1) ---
# Gemini API Key (Recomendado: Usar gemini-2.0-flash-exp)
GEMINI_API_KEY=

# Credenciales de Twilio (Necesarias para llamadas SIP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# URL de la App (Debe ser https://elenaai.tech o la URL de Cloud Run en Europa)
APP_URL=https://elenaai.tech
